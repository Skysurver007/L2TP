#!/bin/bash

#===============================================================================
# NMS Monitoring WiFi - One-Time Installer Token Edition
# Version: 3.0 - Single Use Token System
# Author: System Administrator
# Description: One-time installer with token validation for Linktree/Lynk.id
# Features: Token-based access, usage tracking, self-destruct after use
#===============================================================================

#-------------------------------------------------------------------------------
# KONFIGURASI TOKEN & KEAMANAN
#-------------------------------------------------------------------------------
set -euo pipefail

# === KONFIGURASI TOKEN (UBAH INI) ===
readonly INSTALL_TOKEN="NMS-$(date +%s)-$(openssl rand -hex 4)"  # Ganti dengan token unik Anda
readonly TOKEN_VALID_UNTIL="2024-12-31"           # Expiry date token
readonly MAX_USAGE=1                               # Maksimal penggunaan (1 = sekali)
readonly TOKEN_FILE="/tmp/.nms_token_used"         # File tracking (hidden)
readonly LOCK_FILE="/tmp/.nms_installer_locked"    # File lock permanen

# Warna
readonly RED='\033[0;31m'
readonly GREEN='\033[0;32m'
readonly YELLOW='\033[1;33m'
readonly BLUE='\033[0;34m'
readonly CYAN='\033[0;36m'
readonly PURPLE='\033[0;35m'
readonly WHITE='\033[1;37m'
readonly NC='\033[0m'
readonly BOLD='\033[1m'

# Konfigurasi Installasi
readonly INSTALL_DIR="/root/monitoring-wifi"
readonly SERVICE_NAME="monitoring-wifi"
readonly PORT="5002"
readonly GIT_REPO="https://github.com/Skysurver007/NMS.git"
readonly LOG_FILE="/var/log/monitoring-wifi-install.log"

# Variabel status
INSTALL_STEP=0
TOTAL_STEPS=12
START_TIME=$(date +%s)

#-------------------------------------------------------------------------------
# SISTEM TOKEN & KEAMANAN
#-------------------------------------------------------------------------------

# Fungsi untuk generate URL dengan token (untuk Linktree/Lynk.id)
generate_install_url() {
    local base_url="https://raw.githubusercontent.com/username/repo/main/install-nms.sh"
    echo "${base_url}?token=${INSTALL_TOKEN}"
}

# Cek apakah token sudah expired
check_token_expiry() {
    local current_date=$(date +%Y-%m-%d)
    if [[ "$current_date" > "$TOKEN_VALID_UNTIL" ]]; then
        echo -e "${RED}${BOLD}"
        echo "╔══════════════════════════════════════════════════════════════════╗"
        echo "║                    ⚠️  TOKEN EXPIRED  ⚠️                          ║"
        echo "╠══════════════════════════════════════════════════════════════════╣"
        echo "║                                                                  ║"
        echo "║  This installation link has expired.                             ║"
        echo "║                                                                  ║"
        echo "║  Please contact administrator for a new installation link.       ║"
        echo "║                                                                  ║"
        echo "╚══════════════════════════════════════════════════════════════════╝"
        echo -e "${NC}"
        exit 1
    fi
}

# Cek apakah token sudah pernah digunakan
check_token_usage() {
    # Cek file lock permanen
    if [ -f "$LOCK_FILE" ]; then
        echo -e "${RED}${BOLD}"
        echo "╔══════════════════════════════════════════════════════════════════╗"
        echo "║              🔒  INSTALLATION ALREADY USED  🔒                   ║"
        echo "╠══════════════════════════════════════════════════════════════════╣"
        echo "║                                                                  ║"
        echo "║  This installation link has already been used.                   ║"
        echo "║                                                                  ║"
        echo "║  Each installation link is valid for ONE-TIME use only.          ║"
        echo "║                                                                  ║"
        echo "║  Please request a new installation token from:                   ║"
        echo "║  • Linktree: linktr.ee/yourname                                  ║"
        echo "║  • Lynk.id: lynk.id/yourname                                     ║"
        echo "║                                                                  ║"
        echo "╚══════════════════════════════════════════════════════════════════╝"
        echo -e "${NC}"
        exit 1
    fi

    # Cek file tracking (double check)
    if [ -f "$TOKEN_FILE" ]; then
        local usage_count=$(cat "$TOKEN_FILE" 2>/dev/null || echo "0")
        if [ "$usage_count" -ge "$MAX_USAGE" ]; then
            # Buat file lock permanen
            touch "$LOCK_FILE"
            chmod 000 "$LOCK_FILE"
            check_token_usage  # Recursive call untuk menampilkan pesan lock
        fi
    fi
}

# Mark token sebagai digunakan
mark_token_used() {
    # Buat file tracking
    echo "1" > "$TOKEN_FILE"
    chmod 000 "$TOKEN_FILE"  # Read-only bahkan untuk root
    
    # Buat file lock permanen
    touch "$LOCK_FILE"
    chmod 000 "$LOCK_FILE"
    
    # Log penggunaan
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] Token ${INSTALL_TOKEN} used on $(hostname) - IP: $(curl -s ifconfig.me 2>/dev/null || echo 'unknown')" >> /var/log/nms_token_usage.log 2>/dev/null || true
}

# Validasi token dari parameter (opsional - untuk URL parameter)
validate_token() {
    local input_token="${1:-}"
    
    # Jika tidak ada parameter, cek dari environment atau prompt
    if [ -z "$input_token" ]; then
        # Cek dari environment variable (untuk automated deployment)
        input_token="${NMS_INSTALL_TOKEN:-}"
    fi
    
    # Jika masih kosong, prompt user
    if [ -z "$input_token" ]; then
        echo -e "${CYAN}${BOLD}"
        echo "╔══════════════════════════════════════════════════════════════════╗"
        echo "║              🔐  TOKEN VALIDATION REQUIRED  🔐                   ║"
        echo "╠══════════════════════════════════════════════════════════════════╣"
        echo -e "${NC}"
        echo -e "    ${YELLOW}Please enter your installation token:${NC}"
        echo -e "    ${WHITE}(Get your token from Linktree/Lynk.id)${NC}"
        echo ""
        read -rp "    Token: " input_token
        echo ""
    fi
    
    # Validasi token
    if [ "$input_token" != "$INSTALL_TOKEN" ]; then
        echo -e "${RED}${BOLD}"
        echo "╔══════════════════════════════════════════════════════════════════╗"
        echo "║              ❌  INVALID TOKEN  ❌                               ║"
        echo "╠══════════════════════════════════════════════════════════════════╣"
        echo "║                                                                  ║"
        echo "║  The token you entered is invalid.                               ║"
        echo "║                                                                  ║"
        echo "║  Please check your token and try again, or request a new one:    ║"
        echo "║  • Linktree: linktr.ee/yourname                                  ║"
        echo "║  • Lynk.id: lynk.id/yourname                                     ║"
        echo "║                                                                  ║"
        echo "╚══════════════════════════════════════════════════════════════════╝"
        echo -e "${NC}"
        exit 1
    fi
    
    echo -e "    ${GREEN}✔ Token validated successfully${NC}"
    sleep 1
}

# Self-destruct mechanism (hapus script setelah selesai)
self_destruct() {
    local script_path="$0"
    echo ""
    print_status "info" "Cleaning up installer..."
    
    # Hapus file tracking sementara (tapi biarkan lock file)
    rm -f "$TOKEN_FILE" 2>/dev/null || true
    
    # Schedule self-destruct (hapus script ini sendiri)
    (
        sleep 5
        rm -f "$script_path" 2>/dev/null || true
        # Hapus juga dari history bash
        history -d $(history 1 | awk '{print $1}') 2>/dev/null || true
    ) &
    
    print_status "success" "Installer will self-destruct in 5 seconds..."
}

